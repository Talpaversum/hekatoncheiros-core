APP_RUNTIME_DOCKER_ENABLED=false
APP_CATALOG_AUTO_REFRESH_ENABLED=false
APP_CATALOG_AUTO_REFRESH_INTERVAL_SECONDS=300
HTTPS_SERVER_NAME=localhost
HTTPS_CERT_DIR=./certs
HTTPS_PUBLISHED_PORT=8443
HTTP_REDIRECT_PUBLISHED_PORT=8081
AUTHOR_REGISTRY_URL=
